{
  "name": "@velocity-bpa/n8n-nodes-celo",
  "version": "1.0.0",
  "description": "n8n community node for Celo blockchain operations",
  "license": "bsl-catalog",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy",
    "copy": "copyfiles -u 1 nodes/**/*.{png,jpg,jpeg,gif,svg,json} dist/",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "lint": "eslint nodes credentials --ext .ts",
    "lint:fix": "eslint nodes credentials --fix --ext .ts"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "credentials": [
      "dist/credentials/CeloApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Celo/Celo.node.js"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "jest": "^29.5.0",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "celo",
    "blockchain",
    "cryptocurrency",
    "defi"
  ],
  "author": "Velocity BPA",
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-celo.git"
  }
}